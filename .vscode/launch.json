{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [

        {
            "name": "Plex TV Renamer",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/plex_toolbox/cli/app.py",
            "args": ["tv", "name-files", "${workspaceFolder}/in", "--output-dir", "${workspaceFolder}/out", "--dry-run"],
            "console": "integratedTerminal",
            "justMyCode": true,
            "cwd": "${workspaceFolder}/plex_toolbox",
            "env": {
                "TVDB_API_KEY": "${env:TVDB_API_KEY}"
            }
        }
    ]
}
